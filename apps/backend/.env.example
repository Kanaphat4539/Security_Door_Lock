# คัดลอกเป็น .env แล้วใส่ค่าจริง (.env ถูก gitignore ไว้)

# ---- ฐานข้อมูล ----
# ค่านี้ตรงกับ docker-compose.yml ที่ root ของ repo
# เปิด DB ด้วย: docker compose up -d   (รันที่ root ไม่ใช่ที่ backend/)
DATABASE_URL="mysql://doorlock:doorlock_dev@localhost:3306/doorlock"

# ---- เซิร์ฟเวอร์ ----
# พอร์ตที่ Nest ฟัง — อ่านใน src/main.ts (process.env.PORT ?? 3001)
# ใช้ 3001 เพราะ frontend (Next.js) ใช้ 3000
PORT=3001

# โฟลเดอร์เก็บภาพที่ ESP32-CAM ส่งมา (relative กับที่รัน process)
UPLOAD_DIR=uploads

# ---- Token (บังคับ ถ้าไม่ตั้งเซิร์ฟเวอร์จะไม่ยอมบูต) ----
# สร้างค่าใหม่ด้วย:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# DASHBOARD_TOKEN — ของ Next.js dashboard ใช้ได้ทุก route + เชื่อม WebSocket
# DEVICE_TOKEN    — ฝังใน ESP32-CAM ใช้ได้เฉพาะ POST /access เท่านั้น
#
# ⚠️ แยกกัน 2 ใบโดยตั้งใจ: token ที่ฝังในเฟิร์มแวร์ดึงออกจากบอร์ดที่ flash แล้วได้
#    ถ้าใช้ใบเดียวกัน คนที่ได้บอร์ดไปจะแก้/ลบผู้ใช้ได้ด้วย
DASHBOARD_TOKEN=เปลี่ยนเป็นค่าสุ่มของตัวเอง
DEVICE_TOKEN=เปลี่ยนเป็นค่าสุ่มของตัวเอง

# กุญแจสำหรับเซ็น JWT ของ session ที่ล็อกอิน dashboard และตั๋ว WebSocket
# ถ้าเปลี่ยนค่านี้ ทุกคนจะหลุด session ต้องล็อกอินใหม่
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มของตัวเอง

# ---- รหัสเชิญสำหรับสมัครบัญชี dashboard เอง ----
# คนที่มีรหัสนี้สมัครได้ แต่ได้แค่ role USER (ดูหน้าภาพรวมอย่างเดียว)
# ถ้าจะให้ใครเป็น ADMIN ต้องรัน: npm run db:add-admin -- <username> <password>
#
# ⚠️ ถ้า "ไม่ตั้ง" ค่านี้ = ปิดการสมัครทั้งหมด (สมัครไม่ได้เลย) ซึ่งปลอดภัยกว่า
#    ตั้งเฉพาะตอนที่ต้องการเปิดให้เพื่อนร่วมทีมสมัคร แล้วเปลี่ยนค่าใหม่ทีหลังได้
ADMIN_INVITE_CODE=เปลี่ยนเป็นค่าสุ่มของตัวเอง

# origin ของ dashboard ที่อนุญาตให้ต่อ WebSocket (default http://localhost:3000)
# WS_CORS_ORIGIN=http://localhost:3000

# หมายเหตุ: ไม่มี ALLOWED_UIDS แล้ว
# การตรวจสิทธิ์ย้ายไปอยู่ที่ตาราง User ใน MySQL
# เพิ่มบัตรด้วย: npm run db:add-card -- <UID> "<ชื่อผู้ใช้>"
