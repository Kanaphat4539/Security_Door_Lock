// Security Door Lock — schema ฐานข้อมูล
// URL ของ datasource อ่านจาก DATABASE_URL ผ่าน prisma.config.ts (Prisma 7)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "mysql"
}

/// ค่าตรงกับที่ firmware ส่งมาและที่ frontend ใช้แสดงผลเป๊ะ ๆ
/// อย่าเปลี่ยนตัวพิมพ์ ไม่งั้นสัญญาสามฝั่งจะพัง (ดู CLAUDE.md)
enum Direction {
  in
  out
}

enum AccessStatus {
  granted
  denied
}

/// สิทธิ์ของบัญชี dashboard
/// ADMIN = จัดการบัตร/ผู้ใช้ได้ทั้งหมด
/// USER  = ดูหน้าภาพรวมได้อย่างเดียว แตะ /users ไม่ได้เลย
enum Role {
  ADMIN
  USER
}

/// บัญชีสำหรับ "เข้าใช้ dashboard" — คนละเรื่องกับ User ที่เป็นเจ้าของบัตร RFID
/// (คนที่มีบัตรเข้าประตูได้ ไม่จำเป็นต้องเข้า dashboard ได้ และกลับกันด้วย)
model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique @db.VarChar(64)
  /// รูปแบบ "scrypt:<salt hex>:<hash hex>" — ดู auth/password.ts
  passwordHash String   @db.VarChar(255)
  /// สมัครเองผ่านหน้าเว็บได้แค่ USER — ADMIN ต้องตั้งจาก CLI (db:add-admin)
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// ผู้มีสิทธิ์เข้า-ออก 1 คนต่อ 1 บัตร
model User {
  id        Int      @id @default(autoincrement())
  /// UID ของบัตร RFID เก็บเป็น hex ตัวพิมพ์ใหญ่ไม่มีตัวคั่น เช่น "A1B2C3D4"
  uid       String   @unique @db.VarChar(32)
  name      String   @db.VarChar(191)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs AccessLog[]
}

/// ประวัติการทาบบัตรทุกครั้ง รวมถึงบัตรที่ไม่รู้จัก (userId เป็น null)
model AccessLog {
  id Int @id @default(autoincrement())

  /// เก็บ uid ซ้ำไว้ตรงนี้ด้วย เพราะบัตรที่ไม่รู้จักจะไม่มีแถวใน User ให้อ้างอิง
  /// และถ้าผู้ใช้ถูกลบทีหลัง log ก็ยังต้องบอกได้ว่าบัตรใบไหนมาทาบ
  uid       String       @db.VarChar(32)
  direction Direction
  status    AccessStatus
  /// path ของภาพ มีเฉพาะขาเข้า — ขาออกไม่ถ่ายภาพจึงเป็น null
  imagePath String?      @db.VarChar(255)
  createdAt DateTime     @default(now())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  /// dashboard ดึง log ล่าสุดเป็นหลัก และมีหน้าดูประวัติรายบุคคล
  @@index([createdAt])
  @@index([uid])
  @@index([userId])
}
